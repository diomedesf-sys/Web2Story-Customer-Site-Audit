{
  "name": "website-audit-engine",
  "version": "1.0.0",
  "description": "Custom Website Diagnostic & Audit Tool (Google Ecosystem + Lighthouse)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lighthouse": "^12.0.0",
    "chrome-launcher": "^1.1.2",
    "playwright": "^1.48.0",
    "googleapis": "^144.0.0",
    "@google-analytics/data": "^4.0.0",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "bullmq": "^5.0.0",
    "redis": "^4.7.0",
    "puppeteer": "^23.0.0",
    "ejs": "^3.1.10"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
